---
interface Props {
  transparent?: boolean;
}
const { transparent = false } = Astro.props;
---

<header
  class:list={[
    'fixed top-0 left-0 right-0 z-50 transition-colors',
    transparent ? 'bg-transparent' : 'header-bg',
  ]}
  style={transparent ? '' : 'background-color: rgba(24,19,14,0.92); backdrop-filter: blur(8px); border-bottom: 1px solid rgba(201,133,58,0.20);'}
>
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" aria-label="Ygor Luan Academy">
      <svg viewBox="0 0 240 56" height="36" xmlns="http://www.w3.org/2000/svg" fill="none">
        <rect width="56" height="56" rx="8" fill="var(--copper)"/>
        <polygon points="8,6 17,6 26,44 17,44" fill="var(--espresso)"/>
        <polygon points="39,6 48,6 39,27 30,27" fill="var(--espresso)"/>
        <polygon points="39,27 48,27 48,44 30,44 30,35 39,35" fill="var(--espresso)"/>
        <text x="68" y="27" font-family="'DM Sans', system-ui, sans-serif" font-weight="700" font-size="17" fill="var(--copper)">Ygor Luan</text>
        <text x="68" y="47" font-family="'DM Sans', system-ui, sans-serif" font-weight="700" font-size="17" fill="var(--copper)">Academy</text>
      </svg>
    </a>

    <nav class="flex items-center gap-6">
      <a href="#beneficios" class="text-sm hidden md:block transition-colors" style="color: var(--fade);" onmouseover="this.style.color='var(--cream)'" onmouseout="this.style.color='var(--fade)'">
        Benefícios
      </a>
      <a href="#faq" class="text-sm hidden md:block transition-colors" style="color: var(--fade);" onmouseover="this.style.color='var(--cream)'" onmouseout="this.style.color='var(--fade)'">
        FAQ
      </a>
      <a href="/login" class="btn-ghost text-sm px-4 py-2">
        Entrar
      </a>
    </nav>
  </div>
</header>
