---
import type { Session } from '@supabase/supabase-js';
import '../../styles/global.css';

interface Props {
  title: string;
  session: Session;
  isAdmin?: boolean;
}
const { title, session, isAdmin = false } = Astro.props;
const pathname = Astro.url.pathname;

const navItems = [
  { href: '/dashboard', label: 'Início' },
  { href: '/dashboard/aulas', label: 'Aulas' },
  { href: '/dashboard/mentoria', label: 'Mentoria 1:1' },
  { href: '/dashboard/perfil', label: 'Perfil' },
];

const adminItems = [
  { href: '/admin', label: 'Admin' },
  { href: '/admin/aulas', label: 'Gerenciar Aulas' },
  { href: '/admin/alunos', label: 'Alunos' },
  { href: '/admin/vendas', label: 'Vendas' },
];

const mobileNavItems = [
  {
    href: '/dashboard',
    label: 'Início',
    icon: `<svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M2 6.5L8 1.5L14 6.5V14H10V10H6V14H2V6.5Z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round" fill="none"/></svg>`,
  },
  {
    href: '/dashboard/aulas',
    label: 'Aulas',
    icon: `<svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="1.5" y="2.5" width="13" height="11" rx="1" stroke="currentColor" stroke-width="1.2" fill="none"/><path d="M6.5 5.5L10.5 8L6.5 10.5V5.5Z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round" fill="none"/></svg>`,
  },
  {
    href: '/dashboard/mentoria',
    label: 'Mentoria',
    icon: `<svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="8" cy="5" r="3" stroke="currentColor" stroke-width="1.2" fill="none"/><path d="M2 13.5C2 11 4.69 9 8 9C11.31 9 14 11 14 13.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" fill="none"/></svg>`,
  },
  {
    href: '/dashboard/perfil',
    label: 'Perfil',
    icon: `<svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="8" cy="5" r="3" stroke="currentColor" stroke-width="1.2" fill="none"/><path d="M2 14C2 11.24 4.69 9 8 9C11.31 9 14 11.24 14 14" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" fill="none"/></svg>`,
  },
];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} – Ygor Luan Pro</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <aside class="hidden md:flex flex-col fixed inset-y-0 left-0 w-64" style="background-color: var(--espresso); border-right: 1px solid var(--blade); z-index: 40;">
      <div class="px-6 py-6" style="border-bottom: 1px solid var(--ink);">
        <a href="/" class="font-display text-base font-semibold" style="color: var(--cream);">
          Ygor Luan <span style="color: var(--copper);">Pro</span>
        </a>
      </div>

      <nav class="flex-1 py-6 px-4 space-y-0.5 overflow-y-auto">
        {navItems.map((item) => {
          const isActive = pathname === item.href;
          return (
            <a
              href={item.href}
              class="flex items-center px-3 py-2.5 text-sm font-sans transition-colors"
              style={isActive
                ? 'color: var(--cream); border-left: 2px solid var(--copper); padding-left: calc(0.75rem - 2px); background-color: var(--copper-dim);'
                : 'color: var(--fade); border-left: 2px solid transparent; padding-left: calc(0.75rem - 2px);'}
            >
              {item.label}
            </a>
          );
        })}

        {isAdmin && (
          <>
            <div class="pt-6 pb-2 px-3">
              <span class="font-sans text-xs tracking-[0.15em] uppercase" style="color: var(--blade);">Admin</span>
            </div>
            {adminItems.map((item) => {
              const isActive = pathname.startsWith(item.href);
              return (
                <a
                  href={item.href}
                  class="flex items-center px-3 py-2.5 text-sm font-sans transition-colors"
                  style={isActive
                    ? 'color: var(--cream); border-left: 2px solid var(--copper); padding-left: calc(0.75rem - 2px); background-color: var(--copper-dim);'
                    : 'color: var(--fade); border-left: 2px solid transparent; padding-left: calc(0.75rem - 2px);'}
                >
                  {item.label}
                </a>
              );
            })}
          </>
        )}
      </nav>

      <div class="px-4 py-5" style="border-top: 1px solid var(--ink);">
        <p class="font-sans text-xs truncate mb-3" style="color: var(--fade);">{session.user.email}</p>
        <a href="/api/auth/signout" class="font-sans text-sm link-btn">
          Sair
        </a>
      </div>
    </aside>

    <main class="md:ml-64 pb-20 md:pb-0 min-h-screen p-6 md:p-10" style="background-color: var(--espresso);">
      <slot />
    </main>

    <nav class="md:hidden fixed bottom-0 inset-x-0 flex" style="background-color: var(--mahogany); border-top: 1px solid var(--blade); z-index: 40;">
      {mobileNavItems.map((item) => {
        const isActive = pathname === item.href;
        return (
          <a
            href={item.href}
            class="flex-1 flex flex-col items-center gap-1 py-3 font-sans text-xs transition-colors"
            style={isActive ? 'color: var(--copper);' : 'color: var(--fade);'}
          >
            <span set:html={item.icon} />
            {item.label}
          </a>
        );
      })}
    </nav>
  </body>
</html>
