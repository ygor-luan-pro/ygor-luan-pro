---
import type { User } from '@supabase/supabase-js';
import '../../styles/global.css';

interface Props {
  title: string;
  user: User;
  isAdmin?: boolean;
}
const { title, user, isAdmin = Astro.locals.isAdmin ?? false } = Astro.props;
const pathname = Astro.url.pathname;

const navItems = [
  { href: '/dashboard', label: 'Início' },
  { href: '/dashboard/aulas', label: 'Aulas' },
  { href: '/dashboard/mentoria', label: 'Mentoria 1:1' },
  { href: '/dashboard/perfil', label: 'Perfil' },
  { href: '/dashboard/certificado', label: 'Certificado' },
];

const adminItems = [
  { href: '/admin', label: 'Admin' },
  { href: '/admin/aulas', label: 'Gerenciar Aulas' },
  { href: '/admin/quiz', label: 'Quizzes' },
  { href: '/admin/alunos', label: 'Alunos' },
  { href: '/admin/vendas', label: 'Vendas' },
  { href: '/admin/avaliacoes', label: 'Avaliações' },
  { href: '/admin/certificados', label: 'Certificados' },
];

type MobileNavItem = { href: string; label: string };

const mobileNavItems: MobileNavItem[] = [
  { href: '/dashboard', label: 'Início' },
  { href: '/dashboard/aulas', label: 'Aulas' },
  { href: '/dashboard/mentoria', label: 'Mentoria' },
  { href: '/dashboard/perfil', label: 'Perfil' },
  { href: '/dashboard/certificado', label: 'Cert.' },
];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} – Ygor Luan Academy</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style>
      @media (max-width: 767px) {
        .mobile-main { padding-top: calc(52px + 1.5rem) !important; }
      }
    </style>
  </head>
  <body>
    <header class="md:hidden fixed top-0 inset-x-0 flex items-center justify-between px-4" style="height:52px; background-color:var(--mahogany); border-bottom:1px solid var(--blade); z-index:40;">
      <a href="/" class="flex items-center gap-2">
        <img src="/images/symbol-box-laranja.png" alt="" style="height:28px; width:auto;" />
        <span style="color:var(--copper); font-weight:700; font-size:0.85rem; line-height:1.1;">Ygor Luan<br/>Academy</span>
      </a>
      <button
        id="mobile-menu-btn"
        aria-label="Abrir menu"
        aria-expanded="false"
        style="background:none; border:none; cursor:pointer; color:var(--fade); padding:0.5rem;"
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M3 5H17M3 10H17M3 15H17" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
        </svg>
      </button>
    </header>

    <aside class="hidden md:flex flex-col fixed inset-y-0 left-0 w-64" style="background-color: var(--espresso); border-right: 1px solid var(--blade); z-index: 40;">
      <div class="px-6 py-6" style="border-bottom: 1px solid var(--ink);">
        <a href="/" class="flex items-center gap-2">
          <img src="/images/symbol-box-laranja.png" alt="" height="32" style="height:32px; width:auto;" />
          <span style="color:var(--copper); font-weight:700; font-size:0.9rem; line-height:1.1;">Ygor Luan<br/>Academy</span>
        </a>
      </div>

      <nav class="flex-1 py-6 px-4 space-y-0.5 overflow-y-auto">
        {navItems.map((item) => {
          const isActive = pathname === item.href;
          return (
            <a
              href={item.href}
              class="flex items-center px-3 py-2.5 text-sm font-sans transition-colors"
              style={isActive
                ? 'color: var(--cream); border-left: 2px solid var(--copper); padding-left: calc(0.75rem - 2px); background-color: var(--copper-dim);'
                : 'color: var(--fade); border-left: 2px solid transparent; padding-left: calc(0.75rem - 2px);'}
            >
              {item.label}
            </a>
          );
        })}

        {isAdmin && (
          <>
            <div class="pt-6 pb-2 px-3">
              <span class="font-sans text-xs tracking-[0.15em] uppercase" style="color: var(--blade);">Admin</span>
            </div>
            {adminItems.map((item) => {
              const isActive = item.href === '/admin'
                ? pathname === item.href
                : pathname.startsWith(item.href);
              return (
                <a
                  href={item.href}
                  class="flex items-center px-3 py-2.5 text-sm font-sans transition-colors"
                  style={isActive
                    ? 'color: var(--cream); border-left: 2px solid var(--copper); padding-left: calc(0.75rem - 2px); background-color: var(--copper-dim);'
                    : 'color: var(--fade); border-left: 2px solid transparent; padding-left: calc(0.75rem - 2px);'}
                >
                  {item.label}
                </a>
              );
            })}
          </>
        )}
      </nav>

      <div class="px-4 py-5" style="border-top: 1px solid var(--ink);">
        <p class="font-sans text-xs truncate mb-3" style="color: var(--fade);">{user.email}</p>
        <form method="post" action="/api/auth/signout">
          <button type="submit" class="font-sans text-sm link-btn">Sair</button>
        </form>
      </div>
    </aside>

    <main class="md:ml-64 pb-20 md:pb-0 min-h-screen p-6 md:p-10 mobile-main" style="background-color: var(--espresso);">
      <slot />
    </main>

    <nav class="md:hidden fixed bottom-0 inset-x-0 flex" style="background-color: var(--mahogany); border-top: 1px solid var(--blade); z-index: 40;">
      {mobileNavItems.map((item) => {
        const isActive = pathname === item.href;
        return (
          <a
            href={item.href}
            class="flex-1 flex flex-col items-center gap-1 py-3 font-sans text-xs transition-colors"
            style={isActive ? 'color: var(--copper);' : 'color: var(--fade);'}
          >
            {item.href === '/dashboard' && (
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M2 6.5L8 1.5L14 6.5V14H10V10H6V14H2V6.5Z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round" fill="none"/></svg>
            )}
            {item.href === '/dashboard/aulas' && (
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="1.5" y="2.5" width="13" height="11" rx="1" stroke="currentColor" stroke-width="1.2" fill="none"/><path d="M6.5 5.5L10.5 8L6.5 10.5V5.5Z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round" fill="none"/></svg>
            )}
            {item.href === '/dashboard/mentoria' && (
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="8" cy="5" r="3" stroke="currentColor" stroke-width="1.2" fill="none"/><path d="M2 13.5C2 11 4.69 9 8 9C11.31 9 14 11 14 13.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" fill="none"/></svg>
            )}
            {item.href === '/dashboard/perfil' && (
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="8" cy="5" r="3" stroke="currentColor" stroke-width="1.2" fill="none"/><path d="M2 14C2 11.24 4.69 9 8 9C11.31 9 14 11.24 14 14" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" fill="none"/></svg>
            )}
            {item.href === '/dashboard/certificado' && (
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="1.5" y="2.5" width="13" height="9" rx="1" stroke="currentColor" stroke-width="1.2" fill="none"/>
                <path d="M4.5 6.5H11.5M4.5 9H8.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                <path d="M8 11.5V14" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                <path d="M6 14H10" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
              </svg>
            )}
            {item.label}
          </a>
        );
      })}
    </nav>

    <div id="mobile-overlay" class="md:hidden" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.55); z-index:45;"></div>

    <div
      id="mobile-drawer"
      class="md:hidden"
      style="display:none; position:fixed; top:52px; left:0; right:0; max-height:calc(100vh - 52px - 57px); overflow-y:auto; background-color:var(--espresso); border-bottom:1px solid var(--blade); z-index:50;"
    >
      <div style="display:flex; align-items:center; justify-content:space-between; padding:1rem 1.25rem 0.75rem; border-bottom:1px solid var(--ink);">
        <span class="font-sans text-xs tracking-[0.15em] uppercase" style="color:var(--fade);">Navegação</span>
        <button
          id="mobile-drawer-close"
          style="background:none; border:none; cursor:pointer; color:var(--fade); padding:0.25rem;"
          aria-label="Fechar menu"
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M3 3L13 13M13 3L3 13" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
        </button>
      </div>

      <nav style="padding:0.5rem 1rem;">
        {navItems.map((item) => {
          const isActive = pathname === item.href;
          return (
            <a
              href={item.href}
              class="flex items-center px-3 py-3 font-sans text-sm"
              style={isActive
                ? 'color:var(--cream); border-left:2px solid var(--copper); padding-left:calc(0.75rem - 2px); background-color:var(--copper-dim);'
                : 'color:var(--fade); border-left:2px solid transparent; padding-left:calc(0.75rem - 2px);'}
            >
              {item.label}
            </a>
          );
        })}

        {isAdmin && (
          <>
            <div style="padding:1.25rem 0.75rem 0.5rem;">
              <span class="font-sans text-xs tracking-[0.15em] uppercase" style="color:var(--blade);">Admin</span>
            </div>
            {adminItems.map((item) => {
              const isActive = item.href === '/admin'
                ? pathname === item.href
                : pathname.startsWith(item.href);
              return (
                <a
                  href={item.href}
                  class="flex items-center px-3 py-3 font-sans text-sm"
                  style={isActive
                    ? 'color:var(--cream); border-left:2px solid var(--copper); padding-left:calc(0.75rem - 2px); background-color:var(--copper-dim);'
                    : 'color:var(--fade); border-left:2px solid transparent; padding-left:calc(0.75rem - 2px);'}
                >
                  {item.label}
                </a>
              );
            })}
          </>
        )}

        <div style="padding:1rem 0.75rem; border-top:1px solid var(--ink); margin-top:0.5rem;">
          <p class="font-sans text-xs truncate" style="color:var(--fade); margin-bottom:0.5rem;">{user.email}</p>
          <form method="post" action="/api/auth/signout">
            <button type="submit" class="font-sans text-sm link-btn">Sair</button>
          </form>
        </div>
      </nav>
    </div>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const closeBtn = document.getElementById('mobile-drawer-close');
      const drawer = document.getElementById('mobile-drawer');
      const overlay = document.getElementById('mobile-overlay');

      function openDrawer() {
        drawer!.style.display = 'block';
        overlay!.style.display = 'block';
        btn!.setAttribute('aria-expanded', 'true');
      }

      function closeDrawer() {
        drawer!.style.display = 'none';
        overlay!.style.display = 'none';
        btn!.setAttribute('aria-expanded', 'false');
      }

      btn?.addEventListener('click', () => {
        drawer!.style.display === 'block' ? closeDrawer() : openDrawer();
      });
      closeBtn?.addEventListener('click', closeDrawer);
      overlay?.addEventListener('click', closeDrawer);
    </script>
  </body>
</html>
