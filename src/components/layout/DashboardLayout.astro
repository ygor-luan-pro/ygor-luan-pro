---
import type { Session } from '@supabase/supabase-js';

interface Props {
  title: string;
  session: Session;
}
const { title, session } = Astro.props;
const pathname = Astro.url.pathname;
const isAdmin = session.user.user_metadata?.role === 'admin';

const navItems = [
  { href: '/dashboard', label: 'Início' },
  { href: '/dashboard/aulas', label: 'Aulas' },
  { href: '/dashboard/mentoria', label: 'Mentoria 1:1' },
  { href: '/dashboard/perfil', label: 'Perfil' },
];

const adminItems = [
  { href: '/admin', label: 'Admin' },
  { href: '/admin/aulas', label: 'Gerenciar Aulas' },
  { href: '/admin/alunos', label: 'Alunos' },
  { href: '/admin/vendas', label: 'Vendas' },
];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} – Ygor Luan Academy</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body>
    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <aside class="w-60 flex-col hidden md:flex" style="background-color: var(--espresso); border-right: 1px solid var(--blade);">
        <div class="px-6 py-6" style="border-bottom: 1px solid var(--ink);">
          <a href="/" class="font-display text-base font-semibold" style="color: var(--cream);">
            Ygor Luan <span style="color: var(--copper);">Academy</span>
          </a>
        </div>

        <nav class="flex-1 py-6 px-4 space-y-0.5">
          {navItems.map((item) => {
            const isActive = pathname === item.href;
            return (
              <a
                href={item.href}
                class="flex items-center px-3 py-2.5 text-sm font-sans transition-colors"
                style={isActive
                  ? 'color: var(--cream); border-left: 2px solid var(--copper); padding-left: calc(0.75rem - 2px); background-color: var(--copper-dim);'
                  : 'color: var(--fade); border-left: 2px solid transparent; padding-left: calc(0.75rem - 2px);'}
              >
                {item.label}
              </a>
            );
          })}

          {isAdmin && (
            <>
              <div class="pt-6 pb-2 px-3">
                <span class="font-sans text-xs tracking-[0.15em] uppercase" style="color: var(--blade);">Admin</span>
              </div>
              {adminItems.map((item) => {
                const isActive = pathname.startsWith(item.href);
                return (
                  <a
                    href={item.href}
                    class="flex items-center px-3 py-2.5 text-sm font-sans transition-colors"
                    style={isActive
                      ? 'color: var(--cream); border-left: 2px solid var(--copper); padding-left: calc(0.75rem - 2px); background-color: var(--copper-dim);'
                      : 'color: var(--fade); border-left: 2px solid transparent; padding-left: calc(0.75rem - 2px);'}
                  >
                    {item.label}
                  </a>
                );
              })}
            </>
          )}
        </nav>

        <div class="px-4 py-5" style="border-top: 1px solid var(--ink);">
          <p class="font-sans text-xs truncate mb-3" style="color: var(--fade);">{session.user.email}</p>
          <a href="/api/auth/signout" class="font-sans text-sm transition-colors" style="color: var(--fade);"
            onmouseover="this.style.color='var(--parchment)'" onmouseout="this.style.color='var(--fade)'">
            Sair
          </a>
        </div>
      </aside>

      <!-- Main content -->
      <main class="flex-1 p-6 md:p-10 overflow-y-auto" style="background-color: var(--espresso);">
        <slot />
      </main>
    </div>
  </body>
</html>
