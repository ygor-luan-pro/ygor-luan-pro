---
const year = new Date().getFullYear();
---

<footer class="mt-20 py-10" style="border-top: 1px solid var(--blade);">
  <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-4">
    <p class="text-sm font-sans" style="color: var(--fade);">
      © {year} Ygor Luan Academy. Todos os direitos reservados.
    </p>
    <div class="flex gap-8">
      <a href="/termos" class="text-sm transition-colors" style="color: var(--fade);" onmouseover="this.style.color='var(--parchment)'" onmouseout="this.style.color='var(--fade)'">Termos de Uso</a>
      <a href="/privacidade" class="text-sm transition-colors" style="color: var(--fade);" onmouseover="this.style.color='var(--parchment)'" onmouseout="this.style.color='var(--fade)'">Privacidade</a>
    </div>
  </div>
</footer>
