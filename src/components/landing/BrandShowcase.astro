---

<section class="py-16 px-6" style="background-color: var(--espresso);">
  <div class="max-w-6xl mx-auto">
    <p class="text-center text-sm uppercase tracking-widest mb-10" style="color: var(--copper); font-family: var(--font-mono);">
      Identidade exclusiva para quem leva o ofício a sério
    </p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div class="overflow-hidden rounded-lg">
        <img
          src="/images-panache/YgorLuan%20Logo%20Card%20Ap.png"
          alt="Cartão de visita Ygor Luan Academy"
          class="w-full h-full object-cover"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="overflow-hidden rounded-lg">
        <img
          src="/images-panache/YgorLuan%20Card%201%20Ap.png"
          alt="Papelaria Ygor Luan Academy"
          class="w-full h-full object-cover"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="overflow-hidden rounded-lg">
        <img
          src="/images-panache/YgorLuan%20Bag%20Ap.png"
          alt="Sacola Ygor Luan Academy"
          class="w-full h-full object-cover"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>
