---
import CheckoutButton from '../../islands/CheckoutButton';

interface Props {
  checkoutFailed?: boolean;
}

const { checkoutFailed = false } = Astro.props;
---

<section class="relative min-h-screen flex flex-col justify-end pt-16" style="background-color: var(--espresso);">
  <div class="max-w-6xl mx-auto px-6 pb-20 w-full">
    <div class="flex gap-8 items-start">
      <!-- Blade vertical accent -->
      <div class="hidden md:block w-px self-stretch mt-2" style="background-color: var(--copper); opacity: 0.6;"></div>

      <div class="flex-1 max-w-3xl">
        <p class="font-sans text-sm tracking-[0.2em] uppercase mb-6" style="color: var(--copper);">
          Mentoria exclusiva para barbeiros
        </p>

        <h1 class="font-display font-light leading-[0.92] mb-6" style="font-size: clamp(3.5rem, 9vw, 7rem); color: var(--cream);">
          Domine<br/>
          <span style="font-weight: 600;">sua arte.</span>
        </h1>

        <div class="blade mb-8" style="max-width: 24rem;"></div>

        <p class="font-sans text-lg leading-relaxed mb-10 max-w-xl" style="color: var(--parchment);">
          Aprenda com Ygor Luan as técnicas que transformaram sua carreira.
          Curso completo em vídeo + mentoria 1:1 personalizada.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 items-start mb-12">
          <CheckoutButton client:load initialError={checkoutFailed ? 'Pagamento não concluído. Tente novamente.' : undefined} />
          <a href="#beneficios" class="btn-ghost">
            Ver conteúdo
          </a>
        </div>

        <div class="flex flex-wrap gap-8 font-sans text-sm" style="color: var(--fade);">
          <span>— Acesso vitalício</span>
          <span>— Suporte via mentoria 1:1</span>
          <span>— Atualizações inclusas</span>
        </div>
      </div>

      <div class="hidden lg:block flex-shrink-0 w-72 xl:w-80 self-end">
        <img
          src="/images/ygor-luan-hero.jpg"
          alt="Ygor Luan"
          width="320"
          height="480"
          class="w-full object-cover object-top"
          style="aspect-ratio: 2/3; border: 1px solid rgba(201,133,58,0.30);"
        />
      </div>
    </div>
  </div>
</section>
