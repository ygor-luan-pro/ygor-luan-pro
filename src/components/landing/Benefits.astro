---
const benefits = [
  {
    num: '01',
    title: 'Aulas em vídeo HD',
    desc: 'Mais de 40 aulas gravadas cobrindo técnicas de corte, barba, química e atendimento ao cliente.',
  },
  {
    num: '02',
    title: 'Mentoria 1:1',
    desc: 'Sessão personalizada com Ygor Luan para acelerar sua evolução e tirar dúvidas específicas do seu negócio.',
  },
  {
    num: '03',
    title: 'Materiais complementares',
    desc: 'PDFs, checklists e guias para você aplicar no dia a dia da sua barbearia.',
  },
  {
    num: '04',
    title: 'Acesso vitalício',
    desc: 'Pague uma vez e tenha acesso para sempre, incluindo todas as atualizações futuras.',
  },
];
---

<section id="beneficios" class="py-24 px-6">
  <div class="max-w-4xl mx-auto">
    <p class="font-sans text-sm tracking-[0.2em] uppercase mb-3" style="color: var(--copper);">
      O que você vai receber
    </p>
    <h2 class="font-display font-light leading-tight mb-16" style="font-size: clamp(2rem, 5vw, 3.5rem); color: var(--cream);">
      Tudo que você precisa para<br/>
      <span style="font-weight: 600;">ser referência na sua cidade.</span>
    </h2>

    <div>
      {benefits.map((b) => (
        <div>
          <div class="blade"></div>
          <div class="py-8 flex gap-8 items-start">
            <span class="font-display font-light flex-shrink-0" style="font-size: 3rem; line-height: 1; color: var(--blade); color: rgba(201,133,58,0.25);">
              {b.num}
            </span>
            <div>
              <h3 class="font-display font-semibold text-2xl mb-2" style="color: var(--cream);">
                {b.title}
              </h3>
              <p class="font-sans text-base leading-relaxed" style="color: var(--parchment);">
                {b.desc}
              </p>
            </div>
          </div>
        </div>
      ))}
      <div class="blade"></div>
    </div>
  </div>
</section>
