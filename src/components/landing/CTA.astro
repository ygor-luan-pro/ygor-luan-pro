---
import PricingSection from './PricingSection.astro';
import type { PricingProduct } from '../../types';

const isLaunchMode = import.meta.env.PUBLIC_IS_LAUNCH_MODE === 'true';
const spotsRemaining = parseInt(import.meta.env.PUBLIC_LAUNCH_SPOTS_REMAINING ?? '15', 10);
const premiumPrice = isLaunchMode ? 997 : 1497;

const checkoutUrlVideoaulas = import.meta.env.PUBLIC_CAKTO_CHECKOUT_URL_VIDEOAULAS ?? '#';
const checkoutUrlMentoria = import.meta.env.PUBLIC_CAKTO_CHECKOUT_URL_MENTORIA ?? '#';

const products: PricingProduct[] = [
  {
    checkoutUrl: checkoutUrlVideoaulas,
    eyebrow: 'Começo',
    title: 'Videoaulas',
    features: [
      'Acesso vitalício ao curso',
      'Todas as aulas gravadas',
      'Atualizações incluídas',
      'Suporte por email',
    ],
    price: 297,
    cta: 'Começar agora',
    highlighted: false,
  },
  {
    checkoutUrl: checkoutUrlMentoria,
    eyebrow: 'Completo',
    title: 'Mentoria Completa',
    features: [
      'Tudo do plano Videoaulas',
      '4 sessões de mentoria 1:1',
      'Plano de ação personalizado',
      'Análise do seu trabalho',
      'Estratégia de precificação',
      'Acesso a grupo exclusivo',
    ],
    price: premiumPrice,
    originalPrice: isLaunchMode ? 2500 : undefined,
    cta: 'Garantir vaga',
    highlighted: true,
  },
];
---

<section id="comprar" class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-12">
      <p class="font-sans text-sm tracking-[0.2em] uppercase mb-3" style="color: var(--copper);">
        Investimento
      </p>
      <h2 class="font-display font-light leading-tight mb-4" style="font-size: clamp(2rem, 5vw, 3.5rem); color: var(--cream);">
        Pronto para transformar<br/>
        <span style="font-weight: 600;">sua carreira?</span>
      </h2>
      <p class="font-sans leading-relaxed max-w-xl mx-auto" style="color: var(--parchment);">
        Junte-se a centenas de barbeiros que já evoluíram com o método Ygor Luan.
      </p>
    </div>

    <PricingSection
      isLaunchMode={isLaunchMode}
      spotsRemaining={spotsRemaining}
      products={products}
    />

    <p class="font-sans text-xs text-center mt-8" style="color: var(--fade);">
      Pagamento seguro via Cakto · Parcele em até 12x
    </p>
  </div>
</section>
