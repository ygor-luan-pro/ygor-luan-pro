---
const testimonials = [
  {
    name: 'Carlos M.',
    city: 'São Paulo, SP',
    text: 'Depois da mentoria com o Ygor, dobrei minha clientela em 3 meses. O método dele é cirúrgico.',
    avatar: '/images/testimonials/carlos-m.jpg',
  },
  {
    name: 'Rafael S.',
    city: 'Belo Horizonte, MG',
    text: 'As aulas de técnica de barba mudaram completamente meu trabalho. Vale cada centavo.',
    avatar: '/images/testimonials/rafael-s.jpg',
  },
  {
    name: 'Diego F.',
    city: 'Curitiba, PR',
    text: 'A sessão 1:1 me ajudou a precificar meus serviços corretamente. Hoje ganho 40% mais.',
    avatar: '/images/testimonials/diego-f.jpg',
  },
];
---

<section class="py-24 px-6" style="background-color: var(--mahogany); border-top: 1px solid var(--ink); border-bottom: 1px solid var(--ink);">
  <div class="max-w-6xl mx-auto">
    <p class="font-sans text-sm tracking-[0.2em] uppercase mb-3" style="color: var(--copper);">
      Depoimentos
    </p>
    <h2 class="font-display font-light mb-16" style="font-size: clamp(2rem, 5vw, 3.5rem); color: var(--cream);">
      O que dizem os alunos
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-0">
      {testimonials.map((t, i) => (
        <div class:list={['py-8', i > 0 ? 'md:pl-10 md:border-l' : '']} style={i > 0 ? 'border-left-color: var(--ink);' : ''}>
          {i > 0 && <div class="hidden md:block" style={`border-left: 1px solid var(--ink); margin-left: -1px;`}></div>}
          <span class="font-display font-light block mb-4" style="font-size: 4rem; line-height: 1; color: var(--copper); opacity: 0.4;">"</span>
          <p class="font-sans text-base leading-relaxed mb-6" style="color: var(--parchment);">
            {t.text}
          </p>
          <div class="flex items-center gap-3">
            <img
              src={t.avatar}
              alt={t.name}
              width="40"
              height="40"
              class="rounded-full object-cover flex-shrink-0"
              style="width:40px;height:40px;border:1px solid rgba(201,133,58,0.40);"
            />
            <div>
              <p class="font-sans font-semibold text-sm tracking-wide uppercase" style="color: var(--cream);">
                {t.name}
              </p>
              <p class="font-sans text-xs mt-0.5" style="color: var(--fade);">
                {t.city}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
