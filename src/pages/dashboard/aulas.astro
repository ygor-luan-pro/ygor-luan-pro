---
import DashboardLayout from '../../components/layout/DashboardLayout.astro';
import { LessonsService } from '../../services/lessons.service';
import { ProgressService } from '../../services/progress.service';
import { QuizService } from '../../services/quiz.service';
import { formatDuration, groupLessonsByModule } from '../../lib/utils';

const { user, hasAccess } = Astro.locals;
if (!hasAccess) return Astro.redirect('/sem-acesso');

let lessons: Awaited<ReturnType<typeof LessonsService.getAll>> = [];
let progressList: Awaited<ReturnType<typeof ProgressService.getUserProgress>> = [];
let modulesList: Awaited<ReturnType<typeof LessonsService.getAllModules>> = [];
let quizMap = new Map<number, boolean>();
let aulasLoadError = false;

try {
  [lessons, progressList, modulesList] = await Promise.all([
    LessonsService.getAll(),
    ProgressService.getUserProgress(user!.id),
    LessonsService.getAllModules(),
  ]);
  const quizFlags = await Promise.all(
    modulesList.map(async (m) => ({
      moduleNumber: m.order_number,
      hasQuiz: await QuizService.hasQuestions(m.order_number).catch(() => false),
    }))
  );
  quizMap = new Map(quizFlags.map(({ moduleNumber, hasQuiz }) => [moduleNumber, hasQuiz]));
} catch (err) {
  console.error('Dashboard aulas: erro ao carregar dados', err);
  aulasLoadError = true;
}

const progressMap = new Map(progressList.map((p) => [p.lesson_id, p]));
const moduleTitlesMap = new Map(modulesList.map((m) => [m.order_number, m.title]));

const modules = groupLessonsByModule(lessons);
---

<DashboardLayout title="Aulas" user={user!}>
  <p class="section-eyebrow">Seu conteúdo</p>
  <h1 class="font-display font-light text-4xl mt-1" style="color: var(--cream);">Aulas</h1>
  <div class="page-divider"></div>

  {aulasLoadError && (
    <p class="font-sans text-sm mb-6" style="color: #f87171;">
      Erro ao carregar aulas. Tente recarregar a página.
    </p>
  )}

  {!aulasLoadError && lessons.length === 0 && (
    <div class="card" style="border-color: var(--blade); text-align: center; padding: 3rem 1.5rem;">
      <p class="font-sans font-medium text-sm mb-1" style="color: var(--fade);">Nenhuma aula disponível</p>
      <p class="font-sans text-xs" style="color: var(--blade);">O conteúdo será publicado em breve.</p>
    </div>
  )}

  {!aulasLoadError && (
  <div class="space-y-12">
    {[...modules.entries()].map(([moduleNum, moduleLessons]) => {
      const allDone = moduleLessons.every((l) => progressMap.get(l.id)?.completed);
      const completedInModule = moduleLessons.filter((l) => progressMap.get(l.id)?.completed).length;
      const percentage = moduleLessons.length === 0 ? 0 : Math.round((completedInModule / moduleLessons.length) * 100);
      return (
        <div>
          <div class="flex justify-between font-sans text-xs mb-2" style="color: var(--fade);">
            <span class="flex items-center gap-2">
              {moduleTitlesMap.get(moduleNum) ?? `Módulo ${moduleNum}`}
              {allDone && (
                <span style="color: var(--copper); font-size: 0.7rem; font-variant: small-caps; letter-spacing: 0.05em;">✓ concluído</span>
              )}
            </span>
            <span>{completedInModule} de {moduleLessons.length} concluídas</span>
          </div>
          <div class="h-px mb-4" style="background-color: var(--tobacco);">
            <div
              class="h-full"
              style={`width: ${percentage}%; background-color: var(--copper);`}
            />
          </div>
          <div class={`lesson-timeline${allDone ? ' lesson-timeline--completed' : ''}`}>
            {moduleLessons.map((lesson) => {
              const progress = progressMap.get(lesson.id);
              const done = progress?.completed ?? false;
              return (
                <a
                  href={`/dashboard/aula/${lesson.id}`}
                  class="flex items-center gap-3 py-3 transition-all hover:px-1"
                  style={`border-bottom: 1px solid var(--ink);${done ? ' opacity: 0.65;' : ''}`}
                >
                  <div
                    class="w-6 h-6 flex items-center justify-center flex-shrink-0 font-mono text-xs"
                    style={done
                      ? 'background-color: var(--copper-dim); color: var(--copper); border: 1px solid var(--blade); border-radius: 2px;'
                      : 'background-color: var(--tobacco); color: var(--fade); border: 1px solid var(--ink); border-radius: 2px;'}
                  >
                    {done ? '✓' : lesson.order_number}
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="font-sans font-medium text-sm truncate" style={done ? 'color: var(--parchment);' : 'color: var(--cream);'}>
                      {lesson.title}
                    </p>
                    {lesson.duration_minutes && (
                      <p class="font-sans text-xs mt-0.5" style="color: var(--fade);">{formatDuration(lesson.duration_minutes)}</p>
                    )}
                  </div>
                  <span class="font-sans text-sm flex-shrink-0" style="color: var(--fade);">→</span>
                </a>
              );
            })}
          </div>
          {quizMap.get(moduleNum) && (
            <a
              href={`/dashboard/quiz/${moduleNum}`}
              class="inline-flex items-center gap-2 mt-4 font-sans text-sm transition-colors"
              style="color: var(--copper);"
            >
              Fazer Quiz
            </a>
          )}
        </div>
      );
    })}
  </div>
  )}
</DashboardLayout>
