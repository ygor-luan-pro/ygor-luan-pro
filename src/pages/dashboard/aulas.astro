---
import DashboardLayout from '../../components/layout/DashboardLayout.astro';
import { LessonsService } from '../../services/lessons.service';
import { ProgressService } from '../../services/progress.service';
import { formatDuration } from '../../lib/utils';

const { session } = Astro.locals;
const [lessons, progressList] = await Promise.all([
  LessonsService.getAll(),
  ProgressService.getUserProgress(session!.user.id),
]);

const progressMap = new Map(progressList.map((p) => [p.lesson_id, p]));

const modules = lessons.reduce<Map<number, typeof lessons>>(
  (acc, lesson) => {
    const mod = acc.get(lesson.module_number) ?? [];
    mod.push(lesson);
    acc.set(lesson.module_number, mod);
    return acc;
  },
  new Map(),
);
---

<DashboardLayout title="Aulas" session={session!}>
  <h1 class="font-display font-light text-3xl mb-8" style="color: var(--cream);">Aulas</h1>

  <div class="space-y-10">
    {[...modules.entries()].map(([moduleNum, moduleLessons]) => (
      <div>
        <p class="font-sans text-xs tracking-[0.15em] uppercase mb-4" style="color: var(--copper);">
          Módulo {moduleNum}
        </p>
        <div>
          {moduleLessons.map((lesson) => {
            const progress = progressMap.get(lesson.id);
            const done = progress?.completed ?? false;

            return (
              <a
                href={`/dashboard/aula/${lesson.id}`}
                class="flex items-center gap-5 py-4 transition-colors"
                style={`border-top: 1px solid var(--ink); ${done ? 'opacity: 0.7;' : ''}`}
                onmouseover="this.style.backgroundColor='var(--tobacco)'; this.style.paddingLeft='0.5rem'; this.style.paddingRight='0.5rem';"
                onmouseout="this.style.backgroundColor=''; this.style.paddingLeft=''; this.style.paddingRight='';"
              >
                <div class="w-7 h-7 flex items-center justify-center flex-shrink-0 font-mono text-xs"
                  style={done
                    ? 'background-color: rgba(201,133,58,0.15); color: var(--copper); border: 1px solid var(--blade);'
                    : 'background-color: var(--tobacco); color: var(--fade); border: 1px solid var(--ink);'}>
                  {done ? '✓' : lesson.order_number}
                </div>
                <div class="flex-1 min-w-0">
                  <p class="font-sans font-medium text-sm truncate" style="color: var(--cream);">{lesson.title}</p>
                  {lesson.duration_minutes && (
                    <p class="font-sans text-xs mt-0.5" style="color: var(--fade);">{formatDuration(lesson.duration_minutes)}</p>
                  )}
                </div>
                <span class="font-sans text-sm flex-shrink-0" style="color: var(--blade);">→</span>
              </a>
            );
          })}
          <div style="border-top: 1px solid var(--ink);"></div>
        </div>
      </div>
    ))}
  </div>
</DashboardLayout>
