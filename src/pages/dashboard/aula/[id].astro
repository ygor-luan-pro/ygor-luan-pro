---
import DashboardLayout from '../../../components/layout/DashboardLayout.astro';
import VideoPlayer from '../../../islands/VideoPlayer';
import LessonRating from '../../../islands/LessonRating';
import LessonComments from '../../../islands/LessonComments';
import { LessonsService } from '../../../services/lessons.service';
import { ProgressService } from '../../../services/progress.service';
import { MaterialsService } from '../../../services/materials.service';
import { RatingsService } from '../../../services/ratings.service';
import { findAdjacentLessons } from '../../../lib/utils';

const { user, hasAccess } = Astro.locals;
const { id } = Astro.params;

if (!id) return Astro.redirect('/dashboard/aulas');

if (!hasAccess) return Astro.redirect('/sem-acesso');

const [lesson, progress, materials, allLessons, existingRating] = await Promise.all([
  LessonsService.getById(id).catch(() => null),
  ProgressService.getLessonProgress(user!.id, id).catch(() => null),
  MaterialsService.getByLessonId(id).catch(() => []),
  LessonsService.getAllMinimal().catch(() => []),
  RatingsService.getUserLessonRating(user!.id, id).catch(() => null),
]);

if (!lesson) return Astro.redirect('/dashboard/aulas');

const { prev, next, position, total } = findAdjacentLessons(allLessons, id);
const resolvedMaterials = await Promise.all(
  materials.map(async (material) => ({
    ...material,
    resolvedUrl: await MaterialsService.resolveFileUrl(material.file_url).catch(() => material.file_url),
  })),
);
---

<DashboardLayout title={lesson.title} user={user!}>
  <div class="mb-6 flex items-center justify-between">
    <a href="/dashboard/aulas" class="back-link font-sans text-sm">
      ← Voltar para aulas
    </a>
    {total > 0 && (
      <span class="font-mono text-xs" style="color: var(--fade);">
        Aula {position} de {total}
      </span>
    )}
  </div>

  <h1 class="font-display font-light text-3xl mb-6" style="color: var(--cream);">{lesson.title}</h1>

  <VideoPlayer
    lessonId={lesson.id}
    videoUrl={lesson.video_url}
    initialWatchTime={progress?.watch_time ?? 0}
    initialCompleted={progress?.completed ?? false}
    client:load
  />

  {lesson.description && (
    <div class="mt-6" style="background-color: var(--mahogany); border: 1px solid var(--ink); padding: 1.5rem;">
      <h2 class="font-sans font-medium text-xs tracking-[0.15em] uppercase mb-3" style="color: var(--fade);">Sobre esta aula</h2>
      <p class="font-sans text-sm leading-relaxed" style="color: var(--parchment);">{lesson.description}</p>
    </div>
  )}

  {resolvedMaterials.length > 0 && (
    <div class="mt-6" style="background-color: var(--mahogany); border: 1px solid var(--ink); padding: 1.5rem;">
      <h2 class="font-sans font-medium text-xs tracking-[0.15em] uppercase mb-4" style="color: var(--fade);">
        Materiais desta aula
      </h2>
      <ul class="space-y-2">
        {resolvedMaterials.map((m) => (
          <li>
            <a
              href={m.resolvedUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 font-sans text-sm transition-colors"
              style="color: var(--parchment);"
            >
              <span
                class="font-sans text-xs uppercase tracking-wide px-2 py-0.5"
                style="background-color: var(--espresso); color: var(--copper); border: 1px solid var(--blade);"
              >
                {m.file_type ?? 'ARQ'}
              </span>
              {m.title}
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}

  <LessonRating
    client:load
    lessonId={lesson.id}
    isCompleted={progress?.completed ?? false}
    initialRating={existingRating}
  />

  <LessonComments
    client:load
    lessonId={lesson.id}
    currentUserId={user!.id}
    isAdmin={Astro.locals.isAdmin ?? false}
  />

  <div class="mt-8 flex items-center justify-between gap-4">
    {prev ? (
      <a
        href={`/dashboard/aula/${prev.id}`}
        class="card hover:border-copper transition-colors flex-1 max-w-[48%]"
      >
        <p class="font-sans text-xs uppercase tracking-[0.1em] mb-1" style="color: var(--fade);">← Anterior</p>
        <p class="font-sans font-medium text-sm truncate" style="color: var(--cream);">{prev.title}</p>
      </a>
    ) : (
      <div class="flex-1 max-w-[48%]" aria-hidden="true" />
    )}
    {next ? (
      <a
        href={`/dashboard/aula/${next.id}`}
        class="card hover:border-copper transition-colors flex-1 max-w-[48%] text-right"
      >
        <p class="font-sans text-xs uppercase tracking-[0.1em] mb-1" style="color: var(--fade);">Próxima →</p>
        <p class="font-sans font-medium text-sm truncate" style="color: var(--cream);">{next.title}</p>
      </a>
    ) : (
      <div class="flex-1 max-w-[48%]" aria-hidden="true" />
    )}
  </div>
</DashboardLayout>

<style>
  .back-link {
    color: var(--fade);
    transition: color 0.2s;
  }
  .back-link:hover {
    color: var(--parchment);
  }
</style>
