---
import DashboardLayout from '../../../components/layout/DashboardLayout.astro';
import VideoPlayer from '../../../islands/VideoPlayer';
import { LessonsService } from '../../../services/lessons.service';
import { ProgressService } from '../../../services/progress.service';

const { session } = Astro.locals;
const { id } = Astro.params;

if (!id) return Astro.redirect('/dashboard/aulas');

let lesson;
try {
  lesson = await LessonsService.getById(id);
} catch {
  return Astro.redirect('/dashboard/aulas');
}

const progress = await ProgressService.getLessonProgress(session!.user.id, id);
---

<DashboardLayout title={lesson.title} session={session!}>
  <div class="mb-6">
    <a href="/dashboard/aulas" class="font-sans text-sm transition-colors" style="color: var(--fade);"
      onmouseover="this.style.color='var(--parchment)'" onmouseout="this.style.color='var(--fade)'">
      ← Voltar para aulas
    </a>
  </div>

  <h1 class="font-display font-light text-3xl mb-6" style="color: var(--cream);">{lesson.title}</h1>

  <VideoPlayer
    lessonId={lesson.id}
    videoUrl={lesson.video_url}
    initialWatchTime={progress?.watch_time ?? 0}
    client:load
  />

  {lesson.description && (
    <div class="mt-6" style="background-color: var(--mahogany); border: 1px solid var(--ink); padding: 1.5rem;">
      <h2 class="font-sans font-medium text-xs tracking-[0.15em] uppercase mb-3" style="color: var(--fade);">Sobre esta aula</h2>
      <p class="font-sans text-sm leading-relaxed" style="color: var(--parchment);">{lesson.description}</p>
    </div>
  )}
</DashboardLayout>
