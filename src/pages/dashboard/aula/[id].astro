---
import DashboardLayout from '../../../components/layout/DashboardLayout.astro';
import VideoPlayer from '../../../islands/VideoPlayer';
import { createClient } from '@supabase/supabase-js';
import type { Database } from '../../../types/database.types';

const { session } = Astro.locals;
const { id } = Astro.params;

if (!id) return Astro.redirect('/dashboard/aulas');

const userClient = createClient<Database>(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  {
    auth: { persistSession: false },
    global: { headers: { Authorization: `Bearer ${session!.access_token}` } },
  },
);

const { data: lesson, error: lessonError } = await userClient
  .from('lessons')
  .select('*')
  .eq('id', id)
  .single();

if (lessonError || !lesson) return Astro.redirect('/dashboard/aulas');

const { data: progress } = await userClient
  .from('user_progress')
  .select('*')
  .eq('user_id', session!.user.id)
  .eq('lesson_id', id)
  .single();
---

<DashboardLayout title={lesson.title} session={session!}>
  <div class="mb-6">
    <a href="/dashboard/aulas" class="back-link font-sans text-sm">
      ← Voltar para aulas
    </a>
  </div>

  <h1 class="font-display font-light text-3xl mb-6" style="color: var(--cream);">{lesson.title}</h1>

  <VideoPlayer
    lessonId={lesson.id}
    videoUrl={lesson.video_url}
    initialWatchTime={progress?.watch_time ?? 0}
    initialCompleted={progress?.completed ?? false}
    client:load
  />

  {lesson.description && (
    <div class="mt-6" style="background-color: var(--mahogany); border: 1px solid var(--ink); padding: 1.5rem;">
      <h2 class="font-sans font-medium text-xs tracking-[0.15em] uppercase mb-3" style="color: var(--fade);">Sobre esta aula</h2>
      <p class="font-sans text-sm leading-relaxed" style="color: var(--parchment);">{lesson.description}</p>
    </div>
  )}
</DashboardLayout>

<style>
  .back-link {
    color: var(--fade);
    transition: color 0.2s;
  }
  .back-link:hover {
    color: var(--parchment);
  }
</style>
