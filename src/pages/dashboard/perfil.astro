---
import DashboardLayout from '../../components/layout/DashboardLayout.astro';
import { AuthService } from '../../services/auth.service';
import { OrdersService } from '../../services/orders.service';
import { formatDate } from '../../lib/utils';

const { user } = Astro.locals;

const hasAccess = await OrdersService.hasActiveAccess(user!.id);
if (!hasAccess) return Astro.redirect('/sem-acesso');

if (Astro.request.method === 'POST') {
  await AuthService.resetPassword(user!.email!);
  return Astro.redirect('/dashboard/perfil?reset=sent');
}

const resetSent = Astro.url.searchParams.get('reset') === 'sent';
const profile = await AuthService.getProfile(user!.id);

const initials = profile?.full_name
  ?.split(' ')
  .map((n) => n[0])
  .slice(0, 2)
  .join('')
  .toUpperCase() ?? '?';
---

<DashboardLayout title="Meu Perfil" user={user!}>
  <h1 class="font-display font-light text-4xl" style="color: var(--cream);">Meu Perfil</h1>
  <div class="page-divider"></div>

  <div class="card max-w-md" style="border-color: var(--blade);">
    <div class="flex items-center gap-4 pb-6" style="border-bottom: 1px solid var(--ink);">
      <div class="avatar-circle">
        <span class="font-display text-2xl" style="color: var(--copper);">{initials}</span>
      </div>
      <div>
        <p class="font-display font-semibold text-xl" style="color: var(--cream);">{profile?.full_name ?? user!.email}</p>
        <span class="font-sans text-xs tracking-wide uppercase" style="color: var(--fade);">Aluno</span>
      </div>
    </div>

    <div class="space-y-5 py-6">
      <div>
        <p class="font-sans text-xs tracking-[0.15em] uppercase mb-1" style="color: var(--fade);">E-mail</p>
        <p class="font-sans text-sm" style="color: var(--cream);">{user!.email}</p>
      </div>

      <div>
        <p class="font-sans text-xs tracking-[0.15em] uppercase mb-1" style="color: var(--fade);">Membro desde</p>
        <p class="font-sans text-sm" style="color: var(--cream);">
          {profile ? formatDate(profile.created_at) : '—'}
        </p>
      </div>

      <div class="blade"></div>
    </div>

    {resetSent && (
      <p class="font-sans text-sm mb-4" style="color: var(--copper);">Link de redefinição enviado para seu e-mail.</p>
    )}

    <form method="post">
      <button type="submit" class="btn-ghost text-sm px-4 py-2">
        Alterar senha
      </button>
    </form>
  </div>
</DashboardLayout>
