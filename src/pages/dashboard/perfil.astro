---
import DashboardLayout from '../../components/layout/DashboardLayout.astro';
import { AuthService } from '../../services/auth.service';
import { formatDate } from '../../lib/utils';

const { session } = Astro.locals;
const profile = await AuthService.getProfile(session!.user.id);

const initials = profile?.full_name
  ?.split(' ')
  .map((n) => n[0])
  .slice(0, 2)
  .join('')
  .toUpperCase() ?? '?';
---

<DashboardLayout title="Meu Perfil" session={session!}>
  <h1 class="font-display font-light text-4xl" style="color: var(--cream);">Meu Perfil</h1>
  <div class="page-divider"></div>

  <div class="card max-w-md" style="border-color: var(--blade);">
    <div class="flex items-center gap-4 pb-6" style="border-bottom: 1px solid var(--ink);">
      <div class="avatar-circle">
        <span class="font-display text-2xl" style="color: var(--copper);">{initials}</span>
      </div>
      <div>
        <p class="font-display font-semibold text-xl" style="color: var(--cream);">{profile?.full_name ?? session!.user.email}</p>
        <span class="font-sans text-xs tracking-wide uppercase" style="color: var(--fade);">Aluno</span>
      </div>
    </div>

    <div class="space-y-5 py-6">
      <div>
        <p class="font-sans text-xs tracking-[0.15em] uppercase mb-1" style="color: var(--fade);">E-mail</p>
        <p class="font-sans text-sm" style="color: var(--cream);">{session!.user.email}</p>
      </div>

      <div>
        <p class="font-sans text-xs tracking-[0.15em] uppercase mb-1" style="color: var(--fade);">Membro desde</p>
        <p class="font-sans text-sm" style="color: var(--cream);">
          {profile ? formatDate(profile.created_at) : '—'}
        </p>
      </div>

      <div class="blade"></div>
    </div>

    <a href="/api/auth/reset-password" class="btn-ghost text-sm px-4 py-2">
      Alterar senha
    </a>
  </div>
</DashboardLayout>
