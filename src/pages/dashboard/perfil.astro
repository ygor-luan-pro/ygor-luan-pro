---
import DashboardLayout from '../../components/layout/DashboardLayout.astro';
import { AuthService } from '../../services/auth.service';
import { formatDate } from '../../lib/utils';

const { session } = Astro.locals;
const profile = await AuthService.getProfile(session!.user.id);
---

<DashboardLayout title="Meu Perfil" session={session!}>
  <h1 class="font-display font-light text-3xl mb-8" style="color: var(--cream);">Meu Perfil</h1>

  <div class="max-w-md" style="background-color: var(--mahogany); border: 1px solid var(--ink);">
    <div class="p-8 space-y-6">
      <div>
        <p class="font-sans text-xs tracking-[0.15em] uppercase mb-1" style="color: var(--fade);">E-mail</p>
        <p class="font-sans text-sm" style="color: var(--cream);">{session!.user.email}</p>
      </div>

      <div>
        <p class="font-sans text-xs tracking-[0.15em] uppercase mb-1" style="color: var(--fade);">Nome</p>
        <p class="font-sans text-sm" style="color: var(--cream);">{profile?.full_name ?? '—'}</p>
      </div>

      <div>
        <p class="font-sans text-xs tracking-[0.15em] uppercase mb-1" style="color: var(--fade);">Membro desde</p>
        <p class="font-sans text-sm" style="color: var(--cream);">
          {profile ? formatDate(profile.created_at) : '—'}
        </p>
      </div>

      <div class="pt-4" style="border-top: 1px solid var(--ink);">
        <a href="/api/auth/reset-password" class="btn-ghost text-sm px-4 py-2">
          Alterar senha
        </a>
      </div>
    </div>
  </div>
</DashboardLayout>
