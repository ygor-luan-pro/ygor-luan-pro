---
import DashboardLayout from '../../components/layout/DashboardLayout.astro';

const { session } = Astro.locals;
const calcomLink = import.meta.env.PUBLIC_CALCOM_LINK ?? 'https://cal.com/ygorluan/mentoria';
---

<DashboardLayout title="Mentoria 1:1" session={session!}>
  <h1 class="font-display font-light text-3xl mb-2" style="color: var(--cream);">Mentoria 1:1</h1>
  <p class="font-sans text-sm mb-8" style="color: var(--fade);">
    Agende sua sessão personalizada com Ygor Luan.
  </p>

  <div class="max-w-md" style="background-color: var(--mahogany); border: 1px solid var(--ink);">
    <div class="p-8">
      <p class="font-sans font-medium text-xs tracking-[0.15em] uppercase mb-4" style="color: var(--copper);">
        Sessão de 60 minutos
      </p>
      <p class="font-sans text-sm leading-relaxed mb-8" style="color: var(--parchment);">
        Escolha o melhor horário no calendário de Ygor Luan. Sessão realizada por videoconferência.
      </p>
      <div class="blade mb-8"></div>
      <a
        href={calcomLink}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary"
      >
        Agendar Mentoria →
      </a>
      <p class="font-sans text-xs mt-4" style="color: var(--fade);">
        Você será redirecionado para Cal.com
      </p>
    </div>
  </div>
</DashboardLayout>
