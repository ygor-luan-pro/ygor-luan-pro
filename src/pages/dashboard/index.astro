---
import DashboardLayout from '../../components/layout/DashboardLayout.astro';
import ProgressTracker from '../../islands/ProgressTracker';
import { LessonsService } from '../../services/lessons.service';
import { ProgressService } from '../../services/progress.service';
import { AuthService } from '../../services/auth.service';
import { groupLessonsByModule } from '../../lib/utils';

const { user, hasAccess } = Astro.locals;
if (!hasAccess) return Astro.redirect('/sem-acesso');

let lessons: Awaited<ReturnType<typeof LessonsService.getAll>> = [];
let progressList: Awaited<ReturnType<typeof ProgressService.getUserProgress>> = [];
let modulesList: Awaited<ReturnType<typeof LessonsService.getAllModules>> = [];
let profile: Awaited<ReturnType<typeof AuthService.getProfile>> = null;
let dashboardLoadError = false;

try {
  [lessons, progressList, modulesList, profile] = await Promise.all([
    LessonsService.getAll(),
    ProgressService.getUserProgress(user!.id),
    LessonsService.getAllModules(),
    AuthService.getProfile(user!.id),
  ]);
} catch (err) {
  console.error('Dashboard index: erro ao carregar dados', err);
  dashboardLoadError = true;
}

const progressMap = new Map(progressList.map((p) => [p.lesson_id, p]));
const publishedIds = new Set(lessons.map((l) => l.id));
const completedCount = progressList.filter((p) => p.completed && publishedIds.has(p.lesson_id)).length;
const nextLesson = lessons.find((l) => !progressMap.get(l.id)?.completed) ?? null;

const moduleTitlesMap = new Map(modulesList.map((m) => [m.order_number, m.title]));
const modulesGrouped = groupLessonsByModule(lessons);

const modulesSummary = [...modulesGrouped.entries()].map(([num, lsns]) => ({
  number: num,
  title: moduleTitlesMap.get(num) ?? `Módulo ${num}`,
  total: lsns.length,
  completed: lsns.filter((l) => progressMap.get(l.id)?.completed).length,
  allDone: lsns.every((l) => progressMap.get(l.id)?.completed),
}));

const displayName = profile?.full_name?.split(' ')[0] ?? user!.email?.split('@')[0] ?? 'Artesão';
const isCourseComplete = lessons.length > 0 && completedCount === lessons.length;
---

<DashboardLayout title="Meu Progresso" user={user!}>
  <p class="section-eyebrow">Bem-vindo de volta</p>
  <h1 class="font-display font-light text-4xl mt-1" style="color: var(--cream);">Olá, {displayName}.</h1>
  <div class="page-divider"></div>

  {dashboardLoadError && (
    <p class="font-sans text-sm mb-6" style="color: #f87171;">Erro ao carregar dados. Tente recarregar a página.</p>
  )}

  <div class="mb-6 card" style="border-color: var(--blade);">
    <h2 class="font-sans font-medium text-sm tracking-wide uppercase mb-4" style="color: var(--fade);">Seu progresso</h2>
    <ProgressTracker
      totalLessons={lessons.length}
      completedLessons={completedCount}
      client:load
    />
  </div>

  {nextLesson && (
    <a href={`/dashboard/aula/${nextLesson.id}`} class="card hover:border-copper transition-colors block mb-6">
      <p class="section-eyebrow mb-1">Continuar de onde parou</p>
      <h3 class="font-display font-semibold text-xl" style="color: var(--cream);">{nextLesson.title}</h3>
      <p class="font-sans text-sm mt-4" style="color: var(--copper);">Assistir agora →</p>
    </a>
  )}

  {isCourseComplete && (
    <a
      href="/dashboard/certificado"
      class="card hover:border-copper transition-colors block mb-6"
      style="border-color: var(--copper-dim);"
    >
      <p class="section-eyebrow mb-1">Curso concluído</p>
      <h3 class="font-display font-semibold text-xl" style="color: var(--cream);">
        Seu certificado está pronto
      </h3>
      <p class="font-sans text-sm mt-2" style="color: var(--fade);">
        Você completou todos os módulos da Mentoria Completa de Barbearia.
      </p>
      <p class="font-sans text-sm mt-4" style="color: var(--copper);">Ver certificado →</p>
    </a>
  )}

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {modulesSummary.map((mod) => (
      <a href="/dashboard/aulas" class="card hover:border-copper transition-colors block">
        <div class="flex justify-between items-start mb-2">
          <p class="section-eyebrow">{mod.title}</p>
          {mod.allDone && <span style="color: var(--copper); font-size: 0.7rem; font-variant: small-caps;">✓ concluído</span>}
        </div>
        <p class="font-sans text-sm mb-3" style="color: var(--fade);">
          {mod.completed} de {mod.total} aulas
        </p>
        <div class="h-px" style="background-color: var(--tobacco);">
          <div class="h-full" style={`width: ${mod.total > 0 ? Math.round(mod.completed / mod.total * 100) : 0}%; background-color: var(--copper);`} />
        </div>
      </a>
    ))}
    <a
      href="/dashboard/mentoria"
      class="card hover:border-copper transition-colors block"
    >
      <p class="section-eyebrow mb-2">Mentoria</p>
      <h3 class="font-display font-semibold text-xl mb-1" style="color: var(--cream);">Agendar sessão 1:1</h3>
      <p class="font-sans text-sm" style="color: var(--fade);">60 min · Sessão personalizada com Ygor Luan</p>
      <p class="font-sans text-sm mt-4" style="color: var(--copper);">Agendar →</p>
    </a>
  </div>
</DashboardLayout>
