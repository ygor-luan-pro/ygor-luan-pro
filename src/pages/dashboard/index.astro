---
import DashboardLayout from '../../components/layout/DashboardLayout.astro';
import ProgressTracker from '../../islands/ProgressTracker';
import { LessonsService } from '../../services/lessons.service';
import { ProgressService } from '../../services/progress.service';

const { session } = Astro.locals;
const [lessons, completedCount] = await Promise.all([
  LessonsService.getAll(),
  ProgressService.getCompletedCount(session!.user.id),
]);
---

<DashboardLayout title="Meu Progresso" session={session!}>
  <h1 class="font-display font-light text-3xl mb-8" style="color: var(--cream);">
    Olá, bem-vindo.
  </h1>

  <div class="mb-8" style="background-color: var(--mahogany); border: 1px solid var(--ink); padding: 1.5rem;">
    <h2 class="font-sans font-medium text-sm tracking-wide uppercase mb-4" style="color: var(--fade);">Seu progresso</h2>
    <ProgressTracker
      totalLessons={lessons.length}
      completedLessons={completedCount}
      client:load
    />
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <a href="/dashboard/aulas" class="transition-colors" style="background-color: var(--mahogany); border: 1px solid var(--ink); padding: 1.5rem; display: block;"
      onmouseover="this.style.borderColor='var(--blade)'" onmouseout="this.style.borderColor='var(--ink)'">
      <h3 class="font-sans font-medium mb-1" style="color: var(--cream);">Continuar assistindo</h3>
      <p class="font-sans text-sm" style="color: var(--fade);">{lessons.length} aulas disponíveis</p>
    </a>
    <a href="/dashboard/mentoria" class="transition-colors" style="background-color: var(--mahogany); border: 1px solid var(--ink); padding: 1.5rem; display: block;"
      onmouseover="this.style.borderColor='var(--blade)'" onmouseout="this.style.borderColor='var(--ink)'">
      <h3 class="font-sans font-medium mb-1" style="color: var(--cream);">Agendar mentoria</h3>
      <p class="font-sans text-sm" style="color: var(--fade);">Sessão 1:1 com Ygor Luan</p>
    </a>
  </div>
</DashboardLayout>
