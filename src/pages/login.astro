---
import LoginForm from '../islands/LoginForm';
import '../styles/global.css';

const { session } = Astro.locals;
if (session) return Astro.redirect('/dashboard');
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>Login – Ygor Luan Pro</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen flex">
    <!-- Left panel: espresso -->
    <div class="hidden lg:flex flex-col justify-between w-2/5 p-16" style="background-color: var(--mahogany); border-right: 1px solid var(--blade);">
      <a href="/" class="font-display text-xl font-semibold" style="color: var(--cream);">
        Ygor Luan <span style="color: var(--copper);">Pro</span>
      </a>
      <div>
        <p class="font-display font-light leading-tight mb-4" style="font-size: 2.5rem; color: var(--cream);">
          Sua arte.<br/>
          <span style="font-weight: 600;">Seu negócio.</span>
        </p>
        <p class="font-sans text-sm" style="color: var(--fade);">
          Acesse sua área exclusiva de aluno.
        </p>
      </div>
      <p class="font-sans text-xs" style="color: var(--fade);">
        © {new Date().getFullYear()} Ygor Luan Pro
      </p>
    </div>

    <!-- Right panel: form -->
    <div class="flex-1 flex flex-col items-center justify-center px-6 py-12" style="background-color: var(--espresso);">
      <div class="w-full max-w-sm">
        <div class="lg:hidden mb-10 text-center">
          <a href="/" class="font-display text-xl font-semibold" style="color: var(--cream);">
            Ygor Luan <span style="color: var(--copper);">Pro</span>
          </a>
        </div>

        <h1 class="font-display font-light text-3xl mb-1" style="color: var(--cream);">Bem-vindo</h1>
        <p class="font-sans text-sm mb-8" style="color: var(--fade);">Acesse sua área de aluno</p>

        <div style="background-color: var(--mahogany); border: 1px solid var(--ink); padding: 2rem;">
          <LoginForm client:load />
        </div>

        <p class="text-center font-sans text-sm mt-6" style="color: var(--fade);">
          Ainda não tem acesso?{' '}
          <a href="/#comprar" class="transition-colors" style="color: var(--copper);" onmouseover="this.style.textDecoration='underline'" onmouseout="this.style.textDecoration='none'">Adquira o curso</a>
        </p>
      </div>
    </div>
  </body>
</html>
