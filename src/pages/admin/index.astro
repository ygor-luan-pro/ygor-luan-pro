---
import DashboardLayout from '../../components/layout/DashboardLayout.astro';
import { OrdersService } from '../../services/orders.service';
import { UsersService } from '../../services/users.service';
import { LessonsService } from '../../services/lessons.service';
import { formatCurrency } from '../../lib/utils';

const { user } = Astro.locals;

let totalRevenue = 0;
let totalStudents = 0;
let lessons: Awaited<ReturnType<typeof LessonsService.getAllAdmin>> = [];
let adminLoadError = false;

try {
  [totalRevenue, totalStudents, lessons] = await Promise.all([
    OrdersService.getTotalRevenue(),
    UsersService.countStudents(),
    LessonsService.getAllAdmin(),
  ]);
} catch (err) {
  console.error('Admin index: erro ao carregar dados', err);
  adminLoadError = true;
}
---

<DashboardLayout title="Admin" user={user!} isAdmin={true}>
  <h1 class="font-display font-light text-3xl mb-8" style="color: var(--cream);">Painel Administrativo</h1>

  {adminLoadError && (
    <p class="font-sans text-sm mb-6" style="color: #f87171;">Erro ao carregar dados. Tente recarregar a página.</p>
  )}

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
    <div style="background-color: var(--mahogany); border: 1px solid var(--ink); padding: 1.5rem;">
      <p class="font-mono font-medium leading-none mb-2" style="font-size: 2rem; color: var(--copper);">{formatCurrency(totalRevenue)}</p>
      <p class="font-sans text-xs tracking-[0.1em] uppercase" style="color: var(--fade);">Receita Total</p>
    </div>
    <div style="background-color: var(--mahogany); border: 1px solid var(--ink); padding: 1.5rem;">
      <p class="font-mono font-medium leading-none mb-2" style="font-size: 2rem; color: var(--cream);">{totalStudents}</p>
      <p class="font-sans text-xs tracking-[0.1em] uppercase" style="color: var(--fade);">Alunos</p>
    </div>
    <div style="background-color: var(--mahogany); border: 1px solid var(--ink); padding: 1.5rem;">
      <p class="font-mono font-medium leading-none mb-2" style="font-size: 2rem; color: var(--cream);">{lessons.length}</p>
      <p class="font-sans text-xs tracking-[0.1em] uppercase" style="color: var(--fade);">Aulas</p>
    </div>
  </div>

  <div class="blade mb-8"></div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <a href="/admin/aulas" class="transition-colors hover:border-blade" style="background-color: var(--mahogany); border: 1px solid var(--ink); padding: 1.5rem; display: block;"
>
      <h2 class="font-sans font-medium mb-1" style="color: var(--cream);">Aulas</h2>
      <p class="font-sans text-sm" style="color: var(--fade);">Criar, editar e publicar aulas</p>
    </a>
    <a href="/admin/alunos" class="transition-colors hover:border-blade" style="background-color: var(--mahogany); border: 1px solid var(--ink); padding: 1.5rem; display: block;"
>
      <h2 class="font-sans font-medium mb-1" style="color: var(--cream);">Alunos</h2>
      <p class="font-sans text-sm" style="color: var(--fade);">Lista de alunos cadastrados</p>
    </a>
    <a href="/admin/vendas" class="transition-colors hover:border-blade" style="background-color: var(--mahogany); border: 1px solid var(--ink); padding: 1.5rem; display: block;"
>
      <h2 class="font-sans font-medium mb-1" style="color: var(--cream);">Vendas</h2>
      <p class="font-sans text-sm" style="color: var(--fade);">Relatório de pedidos</p>
    </a>
    <a href="/admin/certificados" class="transition-colors hover:border-blade" style="background-color: var(--mahogany); border: 1px solid var(--ink); padding: 1.5rem; display: block;"
>
      <h2 class="font-sans font-medium mb-1" style="color: var(--cream);">Certificados</h2>
      <p class="font-sans text-sm" style="color: var(--fade);">Certificados emitidos</p>
    </a>
    <a href="/admin/comentarios" class="transition-colors hover:border-blade" style="background-color: var(--mahogany); border: 1px solid var(--ink); padding: 1.5rem; display: block;">
      <h2 class="font-sans font-medium mb-1" style="color: var(--cream);">Comentários</h2>
      <p class="font-sans text-sm" style="color: var(--fade);">Moderação de comentários das aulas</p>
    </a>
  </div>
</DashboardLayout>
