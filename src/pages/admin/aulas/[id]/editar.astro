---
import DashboardLayout from '../../../../components/layout/DashboardLayout.astro';
import AdminLessonForm from '../../../../islands/AdminLessonForm';
import { LessonsService } from '../../../../services/lessons.service';

const { user } = Astro.locals;
const { id } = Astro.params;

if (!id) return Astro.redirect('/admin/aulas');

let lesson;
try {
  lesson = await LessonsService.getById(id);
} catch {
  return Astro.redirect('/admin/aulas');
}
---

<DashboardLayout title="Editar Aula" user={user!} isAdmin={true}>
  <div class="max-w-2xl">
    <div class="mb-6">
      <a href="/admin/aulas" class="font-sans text-sm link-btn">
        ← Voltar
      </a>
    </div>
    <h1 class="font-display font-light text-3xl mb-8" style="color: var(--cream);">Editar: {lesson.title}</h1>
    <div style="background-color: var(--mahogany); border: 1px solid var(--ink); padding: 2rem;">
      <AdminLessonForm mode="edit" lesson={lesson} client:load />
    </div>
  </div>
</DashboardLayout>
