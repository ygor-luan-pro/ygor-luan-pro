---
import DashboardLayout from '../../components/layout/DashboardLayout.astro';
import { UsersService } from '../../services/users.service';
import { formatDate } from '../../lib/utils';

const { session } = Astro.locals;
const students = (await UsersService.getAllAdmin()).filter((u) => u.role === 'student');
---

<DashboardLayout title="Alunos" session={session!}>
  <h1 class="font-display font-light text-3xl mb-8" style="color: var(--cream);">Alunos ({students.length})</h1>

  <div style="background-color: var(--mahogany); border: 1px solid var(--ink);">
    <div class="overflow-x-auto">
      <table class="w-full font-sans text-sm">
        <thead>
          <tr style="border-bottom: 1px solid var(--ink);">
            <th class="text-left px-6 py-3 font-medium text-xs tracking-[0.1em] uppercase" style="color: var(--fade);">Nome</th>
            <th class="text-left px-6 py-3 font-medium text-xs tracking-[0.1em] uppercase" style="color: var(--fade);">E-mail</th>
            <th class="text-left px-6 py-3 font-medium text-xs tracking-[0.1em] uppercase" style="color: var(--fade);">Cadastro</th>
          </tr>
        </thead>
        <tbody>
          {students.map((s) => (
            <tr style="border-bottom: 1px solid var(--ink);">
              <td class="px-6 py-4" style="color: var(--cream);">{s.full_name ?? '—'}</td>
              <td class="px-6 py-4" style="color: var(--parchment);">{s.email}</td>
              <td class="px-6 py-4" style="color: var(--fade);">{formatDate(s.created_at)}</td>
            </tr>
          ))}
        </tbody>
      </table>

      {students.length === 0 && (
        <p class="text-center font-sans text-sm py-10" style="color: var(--fade);">Nenhum aluno cadastrado.</p>
      )}
    </div>
  </div>
</DashboardLayout>
